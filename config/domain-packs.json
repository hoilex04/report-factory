          "keywords": [
            "Robot", "Manipulator", "VLA", "Vision-Language-Action",
            "Grasp", "Navigation", "Locomotion", "Embodiment",
            "Physical AI", "Humanoid", "Bipedal", "Mobile Robot"
          ],
          "color": "#0066CC",
          "metrics": ["latency", "success_rate", "throughput", "efficiency"]
        },
        "AIH": {
          "name": "AI Hardware",
          "description": "AI chips, edge computing, and hardware optimization",
          "keywords": [
            "NPU", "Chip", "AI PC", "Edge Computing", "Hardware",
            "Sensor", "Quantization", "On-device", "Inference optimization",
            "RTX", "GPU", "TPU", "Memory bandwidth", "Power efficiency"
          ],
          "color": "#FF6600",
          "metrics": ["fps", "latency", "power", "memory"]
        },
        "MM": {
          "name": "Multimodal",
          "description": "Vision-language, audio, and cross-modal learning",
          "keywords": [
            "Vision-Language", "Audio", "Video", "Cross-modal",
            "CLIP", "Multimodal", "Speech", "Sound", "Image-text",
            "Video understanding", "Audio-language"
          ],
          "color": "#9933CC",
          "metrics": ["accuracy", "retrieval_score", "generation_quality"]
        },
        "COG": {
          "name": "Cognitive AI",
          "description": "Reasoning, planning, and knowledge systems",
          "keywords": [
            "Reasoning", "Planning", "Memory", "Knowledge Graph",
            "CoT", "Chain-of-Thought", "Logic", "Problem-solving",
            "Inference", "Deduction", "Causal reasoning"
          ],
          "color": "#009933",
          "metrics": ["accuracy", "coverage", "reasoning_steps"]
        },
        "AGT": {
          "name": "Agent",
          "description": "Autonomous agents and multi-agent systems",
          "keywords": [
            "Agent", "Autonomous Agent", "Multi-Agent", "Tool Use",
            "ReAct", "Function Calling", "AI Agent", "AutoGPT",
            "Task planning", "API calling", "MCP"
          ],
          "color": "#CC0066",
          "metrics": ["task_success", "tool_accuracy", "efficiency"]
        }
      }
    },
    "bio_medical": {
      "name": "Bio/Medical",
