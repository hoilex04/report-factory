          "color": "#00CCCC",
          "metrics": ["binding_affinity", "selectivity", "toxicity"]
        },
        "GENO": {
          "name": "Genomics",
          "description": "Genomic analysis and editing",
          "keywords": [
            "Sequencing", "Genome", "CRISPR", "Gene Expression",
