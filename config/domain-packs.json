          ],
          "color": "#FF3399",
          "metrics": ["dice_score", "sensitivity", "specificity"]
        },
        "CLIN": {
          "name": "Clinical AI",
          "description": "Clinical decision support and healthcare AI",
          "keywords": [
            "EHR", "Diagnosis", "Prognosis", "Clinical Trial",
