{
  "version": "2.0",
  "packs": {
    "ai-research": {
      "name": "AI Research",
      "description": "Default pack for AI researchers tracking embodied AI, hardware, multimodal, cognitive, and agent technologies",
      "domains": {
        "EAI": {
          "name": "Embodied AI",
          "keywords": [
            "Robot", "Manipulator", "Locomotion", "Embodied AI", "Grasp",
            "Navigation", "VLA", "Control", "Manipulation", "Humanoid"
          ],
          "color": "#0066CC",
          "metrics": ["latency", "success_rate", "training_time", "zero_shot_pct"]
        },
        "AIH": {
          "name": "AI Hardware",
          "keywords": [
            "NPU", "Chip", "AI PC", "Wearable", "Edge Computing", "Hardware",
            "Sensor", "ASIC", "FPGA", "Quantization", "Inference"
          ],
          "color": "#FF6600",
          "metrics": ["TOPS", "power_W", "memory_GB", "quantization_bits"]
        },
        "MM": {
          "name": "Multimodal",
          "keywords": [
            "Vision-Language", "Audio", "Video Understanding", "Image Generation",
            "Cross-modal", "Text-to-Image", "Multimodal Fusion", "CLIP", "Flamingo"
          ],
          "color": "#9933CC",
          "metrics": ["CLIP_score", "FID", "accuracy", "modality_count"]
        },
        "COG": {
          "name": "Cognitive AI",
          "keywords": [
            "Reasoning", "Planning", "Memory", "Knowledge Graph", "Symbolic AI",
            "Neuro-Symbolic", "Chain-of-Thought", "Tree-of-Thought", "CoT"
          ],
          "color": "#339933",
          "metrics": ["reasoning_steps", "planning_success", "memory_capacity"]
        },
        "AGT": {
          "name": "AI Agents",
          "keywords": [
            "Autonomous Agent", "Multi-Agent", "Tool Use", "ReAct", "LangChain",
            "AutoGPT", "Function Calling", "Agent Framework", "RAG"
          ],
          "color": "#CC3333",
          "metrics": ["task_completion", "tool_success", "collaboration_efficiency"]
        }
      },
      "priority": ["AIH", "EAI", "AGT", "COG", "MM"]
    },
    "bio-medical": {
      "name": "Bio/Medical",
      "description": "For researchers tracking AI applications in drug discovery, genomics, medical imaging, and clinical AI",
      "domains": {
        "DRUG": {
          "name": "Drug Discovery",
          "keywords": [
            "Drug Design", "Molecular", "Binding Affinity", "Screening",
            "ADMET", "Virtual Screening", "De Novo Design"
          ],
          "color": "#0099CC",
          "metrics": ["binding_affinity_nM", "IC50", "ADMET_score", "docking_score"]
        },
        "GENO": {
          "name": "Genomics",
          "keywords": [
            "Sequencing", "Genome", "CRISPR", "Gene Expression",
            "RNA-seq", "Variant Calling", "Epigenetics"
          ],
          "color": "#00CC99",
          "metrics": ["sequencing_depth", "accuracy", "coverage", "F1_score"]
        },
        "MIMG": {
          "name": "Medical Imaging",
          "keywords": [
            "MRI", "CT", "Radiology", "Pathology", "Segmentation",
            "Detection", "Classification", "Ultrasound"
          ],
          "color": "#CC9900",
          "metrics": ["dice_score", "sensitivity", "specificity", "AUC"]
        },
        "CLIN": {
          "name": "Clinical AI",
          "keywords": [
            "EHR", "Diagnosis", "Prognosis", "Clinical Trial",
            "Risk Prediction", "Treatment Recommendation"
          ],
          "color": "#9933CC",
          "metrics": ["accuracy", "precision", "recall", "calibration"]
        }
      },
      "priority": ["DRUG", "MIMG", "CLIN", "GENO"]
    },
    "climate-tech": {
      "name": "Climate Tech",
      "description": "For tracking renewable energy, carbon capture, battery technology, and climate modeling",
      "domains": {
        "REN": {
          "name": "Renewable Energy",
          "keywords": [
            "Solar", "Wind", "Hydro", "Geothermal", "Energy Storage",
            "Photovoltaic", "Turbine"
          ],
          "color": "#FFCC00",
          "metrics": ["efficiency_pct", "capacity_MW", "LCOE", "capacity_factor"]
        },
        "CARB": {
          "name": "Carbon Capture",
          "keywords": [
            "CCS", "Direct Air Capture", "Carbon Sequestration",
            "CO2 Capture", "Mineralization"
          ],
          "color": "#669933",
          "metrics": ["capture_rate", "cost_per_ton", "capacity_tpy"]
        },
        "BATT": {
          "name": "Battery Technology",
          "keywords": [
            "Li-ion", "Solid State", "Energy Density", "BMS",
            "Cathode", "Anode", "Electrolyte"
          ],
          "color": "#3366CC",
          "metrics": ["energy_density_Wh_kg", "cycle_life", "charge_rate", "cost_kWh"]
        },
        "CLIM": {
          "name": "Climate Modeling",
          "keywords": [
            "Climate Simulation", "Weather Prediction", "Risk Model",
            "Earth System", "Downscaling"
          ],
          "color": "#339999",
          "metrics": ["resolution_km", "accuracy", "lead_time", "RMSE"]
        }
      },
      "priority": ["BATT", "REN", "CARB", "CLIM"]
    }
  }
}
